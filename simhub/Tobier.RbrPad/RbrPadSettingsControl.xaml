<UserControl x:Class="Tobier.RbrPad.RbrPadSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Tobier.RbrPad"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel x:Name="Root" Binding.SourceUpdated="Settings_SourceUpdated"
                    d:DataContext="{d:DesignInstance Type=local:RbrPadPluginSettings}">
            <styles:SHSection Title="Controller" ShowSeparator="True">
                <StackPanel>
                    <styles:SHWrapLabel>Rumble controller (XInput slot)</styles:SHWrapLabel>
                    <ComboBox x:Name="ControllerCombo"
                              DisplayMemberPath="Display"
                              SelectionChanged="ControllerCombo_SelectionChanged"
                              Margin="0,0,0,6" />

                    <TextBlock x:Name="NotConnectedWarning"
                               Foreground="#E0B040"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,0,0,6"
                               Text="⚠ Selected controller is not connected. Connect it (or pick another slot) — rumble will do nothing until then." />

                    <StackPanel Orientation="Horizontal">
                        <styles:SHButtonPrimary Click="Refresh_Click" Margin="0,0,6,0">Refresh</styles:SHButtonPrimary>
                        <styles:SHButtonPrimary Click="Test_Click">Test rumble</styles:SHButtonPrimary>
                    </StackPanel>
                </StackPanel>
            </styles:SHSection>

            <styles:SHSectionCheckbox Title="Rumble" ShowSeparator="True" DataContext="{Binding Rumble}"
                                      IsChecked="{Binding Enabled, Mode=TwoWay, NotifyOnSourceUpdated=True}">
                <StackPanel>
                    <styles:SHWrapLabel>Master intensity</styles:SHWrapLabel>
                    <StackPanel Orientation="Horizontal">
                        <Slider Minimum="0" Maximum="1" Width="240"
                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                Value="{Binding MasterIntensity, NotifyOnSourceUpdated=True}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                   Text="{Binding MasterIntensity, StringFormat={}{0:P0}}" />
                    </StackPanel>
                </StackPanel>
            </styles:SHSectionCheckbox>

            <styles:SHSectionCheckbox Title="Surface roughness" ShowSeparator="True" DataContext="{Binding Rumble}"
                                      IsChecked="{Binding RoughnessEnabled, Mode=TwoWay, NotifyOnSourceUpdated=True}">
                <StackPanel>
                    <Border Background="#22FFFFFF" CornerRadius="3" Padding="8,6" Margin="0,0,0,10">
                        <StackPanel>
                            <styles:SHWrapLabel FontWeight="Bold">Live — tune the sliders against these</styles:SHWrapLabel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Width="150" Text="Damper vel (peak):" />
                                <TextBlock x:Name="LiveDamperValue" Text="—" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Width="150" Text="Wheel load (min–max):" />
                                <TextBlock x:Name="LiveLoadValue" Text="—" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Width="150" Text="Heavy motor out (peak):" />
                                <TextBlock x:Name="LiveOutputValue" Text="—" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <styles:SHWrapLabel>Gain</styles:SHWrapLabel>
                    <StackPanel Orientation="Horizontal">
                        <Slider Minimum="0" Maximum="2" Width="240"
                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                Value="{Binding RoughnessGain, NotifyOnSourceUpdated=True}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                   Text="{Binding RoughnessGain, StringFormat={}{0:0.00}}" />
                    </StackPanel>

                    <styles:SHWrapLabel>Response curve (exponent)</styles:SHWrapLabel>
                    <StackPanel Orientation="Horizontal">
                        <Slider Minimum="1" Maximum="4" Width="240"
                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                Value="{Binding RoughnessCurve, NotifyOnSourceUpdated=True}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                   Text="{Binding RoughnessCurve, StringFormat={}{0:0.0}}" />
                    </StackPanel>

                    <styles:SHWrapLabel>Velocity floor (m/s — below this is silent)</styles:SHWrapLabel>
                    <StackPanel Orientation="Horizontal">
                        <Slider Minimum="0" Maximum="1" Width="240"
                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                Value="{Binding DamperVelocityFloor, NotifyOnSourceUpdated=True}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                   Text="{Binding DamperVelocityFloor, StringFormat={}{0:0.00} m/s}" />
                    </StackPanel>

                    <styles:SHWrapLabel>Velocity full (m/s — full contribution)</styles:SHWrapLabel>
                    <StackPanel Orientation="Horizontal">
                        <Slider Minimum="0.5" Maximum="4" Width="240"
                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                Value="{Binding DamperVelocityFull, NotifyOnSourceUpdated=True}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                   Text="{Binding DamperVelocityFull, StringFormat={}{0:0.0} m/s}" />
                    </StackPanel>

                    <styles:SHWrapLabel>Load gate low (N — below this the wheel is muted)</styles:SHWrapLabel>
                    <StackPanel Orientation="Horizontal">
                        <Slider Minimum="0" Maximum="3000" Width="240"
                                TickFrequency="50" IsSnapToTickEnabled="True"
                                Value="{Binding LoadGateLow, NotifyOnSourceUpdated=True}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                   Text="{Binding LoadGateLow, StringFormat={}{0:0} N}" />
                    </StackPanel>

                    <styles:SHWrapLabel>Load gate high (N — full contribution)</styles:SHWrapLabel>
                    <StackPanel Orientation="Horizontal">
                        <Slider Minimum="0" Maximum="6000" Width="240"
                                TickFrequency="100" IsSnapToTickEnabled="True"
                                Value="{Binding LoadGateHigh, NotifyOnSourceUpdated=True}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                   Text="{Binding LoadGateHigh, StringFormat={}{0:0} N}" />
                    </StackPanel>
                </StackPanel>
            </styles:SHSectionCheckbox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
